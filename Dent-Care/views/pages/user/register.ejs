<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login – DentaCare</title>

    <!-- Fonts -->
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;900&family=DM+Sans:wght@300;400;500&display=swap"
        rel="stylesheet">

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- AOS -->
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet" />

    <!-- Particles -->
    <script src="https://cdn.jsdelivr.net/npm/particles.js"></script>

    <style>
        body {
            font-family: 'DM Sans', sans-serif;
            background: #020617;
            color: #e2e8f0;
        }

        h1,
        h2,
        h3 {
            font-family: 'Playfair Display', serif;
        }

        .glass {
            background: rgba(255, 255, 255, 0.04);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .form-input {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 14px 18px;
            border-radius: 12px;
            width: 100%;
            color: #e2e8f0;
            outline: none;
        }

        .form-input:focus {
            border-color: #22d3ee;
            box-shadow: 0 0 0 3px rgba(34, 211, 238, 0.1);
        }

        .error {
            border-color: red !important;
        }

        #navbar.nav-scrolled {
            background: rgba(2, 6, 23, 0.9);
            backdrop-filter: blur(16px);
        }

        #particles-login {
            position: absolute;
            inset: 0;
            z-index: 0;
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
   

    <!-- HERO -->
    <section class="relative  pb-20 text-center overflow-hidden">
    </section>

    <!-- LOGIN FORM -->
    <section class="py-16 px-6">
        <div class="max-w-md mx-auto">

            <div class="glass rounded-3xl p-8" data-aos="zoom-in">

                <h2 class="text-2xl font-bold mb-6 text-center">Login</h2>

                <form  method="post" action="" enctype="multipart/form-data">

                    <!-- USERNAME -->
                    <div class="mb-5">
                        <label class="text-sm text-slate-400">Username</label>
                        <input type="text" name="name" class="form-input" placeholder="Enter username" required />
                        <p  class="text-red-400 text-xs hidden">Min 3 characters</p>
                    </div>

                    <!-- EMAIL -->
                    <div class="mb-5">
                        <label class="text-sm text-slate-400">Email</label>
                        <input type="email" name="email" class="form-input" placeholder="Enter email" required />
                        <p class="text-red-400 text-xs hidden">Invalid email</p>
                    </div>

                    <!-- PHONE -->
                    <div class="mb-5">
                        <label class="text-sm text-slate-400">Phone Number</label>
                        <input type="tel" name="phonnumber" class="form-input" placeholder="" required />
                        <p  class="text-red-400 text-xs hidden">Invalid phone number</p>
                    </div> 
                   <!-- PASSWORD -->
                    <div class="mb-5">
                        <label class="text-sm text-slate-400">Password</label>
                        <input type="password" name="password" class="form-input" placeholder="Enter password" required />
                        <p  class="text-red-400 text-xs hidden">Min 6 characters</p>
                    </div>

                    <!-- CONFIRM PASSWORD -->
                    <div class="mb-3">
                        <label class="text-sm text-slate-400">Confirm Password</label>
                        <input type="password" name="confirmpassword" class="form-input" placeholder="Confirm password" required />
                        <p  class="text-red-400 text-xs hidden">Passwords do not match</p>
                    </div>
                         <div class="mb-3">
                        <label class="text-sm text-slate-400">Profile Image</label>
                        <input type="file" name="image" class="form-input" required />
                        <p  class="text-red-400 text-xs hidden">Enter Profile Image</p>
                    </div>

                    <!-- FORGOT PASSWORD -->
                    <div class="text-right mb-6">
                        <a href="/forgot-password" class="text-cyan-400 text-sm hover:underline">
                            Forgot Password?
                        </a>
                    </div>

                    <!-- BUTTON -->
                    <button
                       type="submit" class="w-full py-3 bg-gradient-to-r from-cyan-500 to-blue-600 rounded-xl font-semibold hover:scale-105 transition">

                        <span>Create Account</span>
                    </button>

                    <!-- LOGIN LINK -->
                    <p class="text-center text-slate-400 text-sm mt-6">
                        Already have an account?
                        <a href="/user/login" class="text-cyan-400 font-medium hover:underline ml-1">
                            Login
                        </a>
                    </p>

                </form>

            </div>
        </div>
    </section>

    <!-- SCROLL TOP -->
    <button id="scrollTop" class="fixed bottom-8 right-8 w-12 h-12 bg-cyan-500 rounded-full hidden"></button>


    <!-- JS -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>

    <!-- YOUR MAIN JS -->
    <script src="/assets/js/main.js"></script>
    <script src="/assets/js/layout.js"></script>

</body>

</html>
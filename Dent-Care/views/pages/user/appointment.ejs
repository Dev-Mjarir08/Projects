<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Book an appointment at DentaCare – Your trusted dental clinic." />
    <title>Book Appointment – DentaCare</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;900&family=DM+Sans:wght@300;400;500;600&display=swap"
        rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/particles.js@2.0.0/particles.min.js"></script>
    <style>
        * {
            font-family: 'DM Sans', sans-serif;
        }

        h1,
        h2,
        h3,
        h4 {
            font-family: 'Playfair Display', serif;
        }

        body {
            background-color: #020617;
            color: #e2e8f0;
            overflow-x: hidden;
        }

        #navbar {
            background: transparent;
        }

        #navbar.nav-scrolled {
            background: rgba(2, 6, 23, 0.92);
            backdrop-filter: blur(16px);
            padding-top: 0.75rem !important;
            padding-bottom: 0.75rem !important;
        }

        #scrollTop {
            display: none;
        }

        .glass {
            background: rgba(255, 255, 255, 0.04);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .grad-text {
            background: linear-gradient(135deg, #67e8f9, #3b82f6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .glow-btn {
            box-shadow: 0 0 20px rgba(6, 182, 212, 0.4);
        }

        .form-input {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 14px 18px;
            color: #e2e8f0;
            width: 100%;
            transition: border-color .3s, box-shadow .3s;
            outline: none;
            font-family: 'DM Sans', sans-serif;
        }

        .form-input::placeholder {
            color: #475569;
        }

        .form-input:focus {
            border-color: rgba(34, 211, 238, 0.5);
            box-shadow: 0 0 0 3px rgba(34, 211, 238, 0.1);
        }

        .form-input.error {
            border-color: rgba(239, 68, 68, 0.6);
            box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
        }

        .field-error {
            color: #f87171;
            font-size: 0.75rem;
            margin-top: 4px;
            display: none;
        }

        select.form-input option {
            background: #1e293b;
            color: #e2e8f0;
        }

        #particles-appt {
            position: absolute;
            inset: 0;
            z-index: 0;
        }

        .success-toast {
            display: none;
        }
    </style>
</head>

<body>
    <div id="custom-cursor"></div>
    <div id="cursor-dot"></div>
    <div id="nav-placeholder"></div>

    <!-- Hero -->
    <section
        class="relative pt-36 pb-20 px-6 lg:px-16 overflow-hidden bg-gradient-to-br from-slate-950 via-blue-950/30 to-slate-950">
        <div id="particles-appt"></div>
        <div class="relative z-10 max-w-7xl mx-auto text-center">
            <p class="text-cyan-500 text-sm font-medium tracking-widest uppercase mb-3" data-aos="fade-up">Schedule a
                Visit</p>
            <h1 class="text-5xl md:text-6xl font-black text-white mb-6" data-aos="fade-up" data-aos-delay="100">
                Book Your <span class="grad-text">Appointment</span>
            </h1>
            <p class="text-slate-400 text-lg max-w-xl mx-auto" data-aos="fade-up" data-aos-delay="200">
                Fill out the form below and our team will confirm your appointment within 2 hours.
            </p>
        </div>
    </section>

    <!-- Form Section -->
    <section class="py-16 px-6 lg:px-16 bg-slate-950">
        <div class="max-w-6xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

                <!-- Info sidebar -->
                <div class="space-y-6" data-aos="fade-right">
                    <div class="glass rounded-2xl p-6">
                        <div
                            class="w-12 h-12 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center mb-4">
                            <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <h3 class="text-white font-semibold mb-2">Working Hours</h3>
                        <p class="text-slate-400 text-sm">Mon – Fri: 8:00 AM – 7:00 PM</p>
                        <p class="text-slate-400 text-sm">Saturday: 9:00 AM – 5:00 PM</p>
                        <p class="text-slate-500 text-sm">Sunday: Closed</p>
                    </div>
                    <div class="glass rounded-2xl p-6">
                        <div
                            class="w-12 h-12 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center mb-4">
                            <svg class="w-6 h-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                            </svg>
                        </div>
                        <h3 class="text-white font-semibold mb-2">Emergency?</h3>
                        <p class="text-slate-400 text-sm mb-3">We offer same-day emergency appointments. Call us
                            directly:</p>
                        <a href="tel:+15551234567" class="text-cyan-400 font-semibold">+1 (555) 123-4567</a>
                    </div>
                    <div class="glass rounded-2xl p-6">
                        <div
                            class="w-12 h-12 rounded-xl bg-green-500/10 border border-green-500/20 flex items-center justify-center mb-4">
                            <svg class="w-6 h-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <h3 class="text-white font-semibold mb-2">What to Expect</h3>
                        <ul class="space-y-2">
                            <li class="flex items-center gap-2 text-slate-400 text-sm"><span
                                    class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>Confirmation within 2 hrs</li>
                            <li class="flex items-center gap-2 text-slate-400 text-sm"><span
                                    class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>Free first consultation</li>
                            <li class="flex items-center gap-2 text-slate-400 text-sm"><span
                                    class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>Flexible cancellation</li>
                        </ul>
                    </div>
                </div>

                <!-- Form -->
                <div class="lg:col-span-2" data-aos="fade-left">
                    <div class="glass rounded-3xl p-8 lg:p-10">
                        <h2 class="text-3xl font-bold text-white mb-2">Request an Appointment</h2>
                        <p class="text-slate-500 text-sm mb-8">All fields marked with * are required.</p>

                        <!-- Success Toast -->
                        <div id="successToast"
                            class="success-toast mb-6 bg-green-500/10 border border-green-500/30 rounded-2xl p-5 flex items-center gap-3">
                            <div
                                class="w-10 h-10 rounded-full bg-green-500/20 flex items-center justify-center shrink-0">
                                <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24"
                                    stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M5 13l4 4L19 7" />
                                </svg>
                            </div>
                            <div>
                                <p class="text-green-400 font-semibold">Appointment Requested!</p>
                                <p class="text-slate-400 text-sm">We'll confirm within 2 hours. See you soon!</p>
                            </div>
                        </div>

                        <form id="appointmentForm" novalidate>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
                                <!-- Name -->
                                <div>
                                    <label
                                        class="block text-slate-400 text-xs font-medium mb-2 tracking-wide uppercase">Full
                                        Name *</label>
                                    <input type="text" id="name" placeholder="John Smith" class="form-input" />
                                    <p class="field-error" id="nameError">Please enter your full name.</p>
                                </div>
                                <!-- Email -->
                                <div>
                                    <label
                                        class="block text-slate-400 text-xs font-medium mb-2 tracking-wide uppercase">Email
                                        Address *</label>
                                    <input type="email" id="email" placeholder="john@example.com" class="form-input" />
                                    <p class="field-error" id="emailError">Please enter a valid email address.</p>
                                </div>
                                <!-- Phone -->
                                <div>
                                    <label
                                        class="block text-slate-400 text-xs font-medium mb-2 tracking-wide uppercase">Phone
                                        Number *</label>
                                    <input type="tel" id="phone" placeholder="+1 (555) 000-0000" class="form-input" />
                                    <p class="field-error" id="phoneError">Please enter a valid phone number.</p>
                                </div>
                                <!-- Date -->
                                <div>
                                    <label
                                        class="block text-slate-400 text-xs font-medium mb-2 tracking-wide uppercase">Preferred
                                        Date *</label>
                                    <input type="date" id="date" class="form-input" />
                                    <p class="field-error" id="dateError">Please select a future date.</p>
                                </div>
                                <!-- Service -->
                                <div>
                                    <label
                                        class="block text-slate-400 text-xs font-medium mb-2 tracking-wide uppercase">Service
                                        *</label>
                                    <select id="service" class="form-input">
                                        <option value="">Select a service…</option>
                                        <option>Teeth Cleaning</option>
                                        <option>Root Canal</option>
                                        <option>Dental Braces</option>
                                        <option>Teeth Whitening</option>
                                        <option>Dental Implants</option>
                                        <option>Dental Veneers</option>
                                        <option>General Check-up</option>
                                        <option>Other</option>
                                    </select>
                                    <p class="field-error" id="serviceError">Please select a service.</p>
                                </div>
                                <!-- Doctor -->
                                <div>
                                    <label
                                        class="block text-slate-400 text-xs font-medium mb-2 tracking-wide uppercase">Preferred
                                        Doctor</label>
                                    <select id="doctor" class="form-input">
                                        <option value="">No preference</option>
                                        <option>Dr. Emily Johnson</option>
                                        <option>Dr. Marcus Chen</option>
                                        <option>Dr. Priya Patel</option>
                                        <option>Dr. Robert Walsh</option>
                                    </select>
                                </div>
                            </div>
                            <!-- Message -->
                            <div class="mb-8">
                                <label
                                    class="block text-slate-400 text-xs font-medium mb-2 tracking-wide uppercase">Additional
                                    Notes</label>
                                <textarea id="message" rows="4"
                                    placeholder="Tell us about your concerns or any relevant medical history…"
                                    class="form-input resize-none"></textarea>
                            </div>
                            <button type="submit" id="submitBtn"
                                class="w-full py-4 bg-gradient-to-r from-cyan-500 to-blue-600 text-white font-semibold rounded-2xl glow-btn hover:-translate-y-0.5 transition-all duration-300 flex items-center justify-center gap-2">
                                <span id="btnText">Request Appointment</span>
                                <svg id="btnArrow" class="w-4 h-4" fill="none" viewBox="0 0 24 24"
                                    stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                </svg>
                                <svg id="btnSpinner" class="w-5 h-5 animate-spin hidden"
                                    xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor"
                                        stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor"
                                        d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                                </svg>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div id="footer-placeholder"></div>
    <button id="scrollTop"
        class="fixed bottom-8 right-8 w-12 h-12 bg-gradient-to-br from-cyan-500 to-blue-600 rounded-full flex items-center justify-center shadow-lg hover:-translate-y-1 transition-all duration-300 z-40">
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
        </svg>
    </button>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <script src="/assets/js/layout.js"></script>
    <script src="/assets/js/particales.config,js"></script>
    <script src="/assets/js/main.js"></script>
    <script>
        /* ── Form Validation ── */
        $(document).ready(function () {

            // Set min date to tomorrow
            const tomorrow = new Date();
            tomorrow.setDate(tomorrow.getDate() + 1);
            $('#date').attr('min', tomorrow.toISOString().split('T')[0]);

            function showError(id, msg) {
                $('#' + id).css('display', 'block').text(msg);
                $('#' + id.replace('Error', '')).addClass('error');
            }
            function clearError(id) {
                $('#' + id).hide();
                $('#' + id.replace('Error', '')).removeClass('error');
            }

            // Live clear on input
            $('input, select, textarea').on('input change', function () {
                clearError(this.id + 'Error');
            });

            $('#appointmentForm').on('submit', function (e) {
                e.preventDefault();
                let valid = true;

                const name = $('#name').val().trim();
                const email = $('#email').val().trim();
                const phone = $('#phone').val().trim();
                const date = $('#date').val();
                const service = $('#service').val();

                if (name.length < 2) { showError('nameError', 'Please enter your full name (min 2 chars).'); valid = false; }
                if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showError('emailError', 'Please enter a valid email.'); valid = false; }
                if (!/^[+\d\s\-\(\)]{7,15}$/.test(phone)) { showError('phoneError', 'Please enter a valid phone number.'); valid = false; }
                if (!date) { showError('dateError', 'Please select a preferred date.'); valid = false; }
                if (!service) { showError('serviceError', 'Please select a service.'); valid = false; }

                if (!valid) return;

                // Simulate submission
                $('#btnText').text('Submitting…');
                $('#btnArrow').hide();
                $('#btnSpinner').removeClass('hidden');
                $('#submitBtn').prop('disabled', true);

                setTimeout(function () {
                    $('#appointmentForm')[0].reset();
                    $('#btnText').text('Request Appointment');
                    $('#btnArrow').show();
                    $('#btnSpinner').addClass('hidden');
                    $('#submitBtn').prop('disabled', false);
                    $('#successToast').slideDown(400).css('display', 'flex');
                    $('html,body').animate({ scrollTop: $('#successToast').offset().top - 100 }, 500);
                }, 1800);
            });

            // Init particles
            initParticles('particles-appt');
        });
    </script>
</body>

</html>
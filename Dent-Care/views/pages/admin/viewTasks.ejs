<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task List</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #f5f7fb;
            display: flex;
            justify-content: center;
            padding: 40px 15px;
        }

        /* Card */
        .card-table {
            width: 900px;
            background: #fff;
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        /* Header */
        .title {
            font-weight: 600;
            font-size: 1rem;
        }

        /* Table */
        .table {
            margin-top: 10px;
        }

        .table thead th {
            font-size: 0.75rem;
            color: #6b7280;
            font-weight: 500;
            border-bottom: 1px solid #e5e7eb;
        }

        .table td {
            font-size: 0.85rem;
            border-bottom: 1px solid #f1f5f9;
        }

        /* Hover */
        .table tbody tr:hover {
            background: #f9fafb;
        }

        /* Action buttons */
        .btn-action {
            border: none;
            background: transparent;
            color: #6b7280;
            padding: 5px;
        }

        .btn-action:hover {
            color: #111;
        }

        .btn-delete:hover {
            color: #dc3545;
        }

        /* Badge */
        .badge-clean {
            background: #e6f7ed;
            color: #146b3a;
            font-size: 0.7rem;
            padding: 4px 8px;
            border-radius: 20px;
        }
    </style>
</head>

<body>

    <div class="card-table">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-2">
            <div class="title">Task List</div>

            <a href="/admin/task/create" class="btn btn-sm btn-success">
                <i class="bi bi-plus"></i> Add Task
            </a>
        </div>

        <!-- Table -->
        <table class="table align-middle">

            <thead>
                <tr>
                    <th>#</th>
                    <th>Task</th>
                    <th>Description</th>
                    <th>Assigned To</th>
                    <th>Created By</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>

                <% if (tasks.length===0) { %>
                    <tr>
                        <td colspan="6" class="text-center text-muted">
                            No tasks found
                        </td>
                    </tr>
                    <% } %>

                        <% tasks.forEach((task, index)=> { %>
                            <tr>
                                <td>
                                    <%= index + 1 %>
                                </td>

                                <td class="fw-medium">
                                    <%= task.name %>
                                </td>

                                <td>
                                    <%= task.description.length> 30
                                        ? task.description.substring(0, 30) + '...'
                                        : task.description %>
                                </td>

                                <!-- populate required -->
                                <td>
                                    <span class="badge-clean">
                                        <%= task.assignedTo?.name %>
                                    </span>
                                </td>

                                <td>
                                    <%= task.createdBy?.name %>
                                </td>

                                <td class="text-end">

                               <% if(user.role === 'admin') { %>
                                    <a href="/admin/editTask/<%= task._id %>" class="btn-action">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <a href="/admin/deleteTask/<%= task._id %>" class="btn-action btn-delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                <% } %>

                                </td>
                            </tr>
                            <% }) %>

            </tbody>

        </table>

    </div>

</body>

</html>